<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_chantier_chantier" model="ir.sequence">
        <field name="name">Chantier</field>
        <field name="code">chantier.chantier</field>
        <field name="prefix">CHT/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_chantier_devis" model="ir.sequence">
        <field name="name">Devis chantier</field>
        <field name="code">chantier.devis</field>
        <field name="prefix">DEV/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_chantier_facture" model="ir.sequence">
        <field name="name">Facture chantier</field>
        <field name="code">chantier.facture</field>
        <field name="prefix">FAC/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_chantier_commande_fournisseur" model="ir.sequence">
        <field name="name">Commande fournisseur chantier</field>
        <field name="code">chantier.commande.fournisseur</field>
        <field name="prefix">CMD/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
