<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_chantier_chantier" model="ir.sequence">
        <field name="name">Chantier</field>
        <field name="code">chantier.chantier</field>
        <field name="prefix">CHT/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_chantier_avenant" model="ir.sequence">
        <field name="name">Avenant chantier</field>
        <field name="code">chantier.avenant</field>
        <field name="prefix">AVN/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
