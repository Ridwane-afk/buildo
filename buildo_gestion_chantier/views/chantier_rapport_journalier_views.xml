<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_chantier_rapport_journalier_form" model="ir.ui.view">
        <field name="name">chantier.rapport.journalier.form</field>
        <field name="model">chantier.rapport.journalier</field>
        <field name="arch" type="xml">
            <form string="Rapport journalier">
                <sheet>
                    <group>
                        <group>
                            <field name="chantier_id"/>
                            <field name="auteur_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="meteo"/>
                            <field name="nb_ouvriers"/>
                        </group>
                    </group>
                    <group string="Travaux réalisés">
                        <field name="travaux_realises" nolabel="1" placeholder="Décrire les travaux effectués..."/>
                    </group>
                    <group string="Incidents / Remarques">
                        <field name="incidents" nolabel="1" placeholder="Incidents, problèmes, remarques..."/>
                    </group>
                    <group string="Notes complémentaires">
                        <field name="note" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_chantier_rapport_journalier_list" model="ir.ui.view">
        <field name="name">chantier.rapport.journalier.list</field>
        <field name="model">chantier.rapport.journalier</field>
        <field name="arch" type="xml">
            <list string="Rapports journaliers">
                <field name="date"/>
                <field name="chantier_id"/>
                <field name="auteur_id"/>
                <field name="meteo"/>
                <field name="nb_ouvriers"/>
            </list>
        </field>
    </record>

    <record id="action_chantier_rapport_journalier" model="ir.actions.act_window">
        <field name="name">Rapports journaliers</field>
        <field name="res_model">chantier.rapport.journalier</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
