<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Ajout chantier_id sur le formulaire de facture -->
    <record id="view_account_move_form_chantier" model="ir.ui.view">
        <field name="name">account.move.form.chantier</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="chantier_id"
                       invisible="move_type not in ('out_invoice','out_refund')"/>
                <field name="pourcentage_avancement"
                       invisible="not chantier_id or move_type not in ('out_invoice','out_refund')"
                       string="Avancement facturé (%)"/>
            </xpath>
        </field>
    </record>

    <!-- Action : factures liées aux chantiers -->
    <record id="action_account_move_chantier" model="ir.actions.act_window">
        <field name="name">Factures chantiers</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('chantier_id', '!=', False), ('move_type', '=', 'out_invoice')]</field>
        <field name="context">{'default_move_type': 'out_invoice'}</field>
    </record>
</odoo>
