<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ─── PHOTOS ─── -->
    <record id="view_chantier_photo_form" model="ir.ui.view">
        <field name="name">chantier.photo.form</field>
        <field name="model">chantier.photo</field>
        <field name="arch" type="xml">
            <form string="Photo de chantier">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="chantier_id"/>
                            <field name="date"/>
                            <field name="auteur_id"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Description de la photo..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_chantier_photo_list" model="ir.ui.view">
        <field name="name">chantier.photo.list</field>
        <field name="model">chantier.photo</field>
        <field name="arch" type="xml">
            <list string="Photos">
                <field name="chantier_id"/>
                <field name="name"/>
                <field name="date"/>
                <field name="auteur_id"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_chantier_photo_kanban" model="ir.ui.view">
        <field name="name">chantier.photo.kanban</field>
        <field name="model">chantier.photo</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="image"/>
                <field name="chantier_id"/>
                <field name="date"/>
                <templates>
                    <t t-name="card">
                        <img t-att-src="kanban_image('chantier.photo', 'image', record.id.value)"
                             t-att-alt="record.name.value"
                             style="max-height:150px; object-fit:cover; width:100%; border-radius:4px;"/>
                        <div class="p-2">
                            <strong><field name="name"/></strong>
                            <div class="text-muted"><field name="chantier_id"/></div>
                            <div><field name="date"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_chantier_photo" model="ir.actions.act_window">
        <field name="name">Photos</field>
        <field name="res_model">chantier.photo</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- ─── PLANS ─── -->
    <record id="view_chantier_plan_form" model="ir.ui.view">
        <field name="name">chantier.plan.form</field>
        <field name="model">chantier.plan</field>
        <field name="arch" type="xml">
            <form string="Plan de chantier">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="chantier_id"/>
                            <field name="version"/>
                            <field name="date"/>
                            <field name="auteur_id"/>
                        </group>
                        <group>
                            <field name="fichier" filename="fichier_name" widget="binary"/>
                            <field name="fichier_name"/>
                        </group>
                    </group>
                    <field name="annotation" placeholder="Annotations sur ce plan..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_chantier_plan_list" model="ir.ui.view">
        <field name="name">chantier.plan.list</field>
        <field name="model">chantier.plan</field>
        <field name="arch" type="xml">
            <list string="Plans">
                <field name="chantier_id"/>
                <field name="name"/>
                <field name="version"/>
                <field name="date"/>
                <field name="auteur_id"/>
                <field name="fichier_name"/>
            </list>
        </field>
    </record>

    <record id="action_chantier_plan" model="ir.actions.act_window">
        <field name="name">Plans</field>
        <field name="res_model">chantier.plan</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
