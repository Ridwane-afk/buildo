<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_chantier_avenant_form" model="ir.ui.view">
        <field name="name">chantier.avenant.form</field>
        <field name="model">chantier.avenant</field>
        <field name="arch" type="xml">
            <form string="Avenant">
                <header>
                    <button name="action_accepter" string="Accepter" type="object"
                            invisible="state != 'brouillon'" class="btn-primary"/>
                    <button name="action_refuser" string="Refuser" type="object"
                            invisible="state != 'brouillon'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="brouillon,accepte"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="devis_id"/>
                            <field name="chantier_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="montant_ht"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Motif de la modification">
                        <field name="motif" nolabel="1" placeholder="Décrivez la raison de cet avenant..."/>
                    </group>
                    <field name="note" placeholder="Notes complémentaires..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_chantier_avenant_list" model="ir.ui.view">
        <field name="name">chantier.avenant.list</field>
        <field name="model">chantier.avenant</field>
        <field name="arch" type="xml">
            <list string="Avenants" decoration-success="state == 'accepte'"
                  decoration-danger="state == 'refuse'">
                <field name="name"/>
                <field name="devis_id"/>
                <field name="chantier_id"/>
                <field name="date"/>
                <field name="motif"/>
                <field name="montant_ht" sum="Total"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'accepte'"
                       decoration-danger="state == 'refuse'"/>
            </list>
        </field>
    </record>

    <record id="action_chantier_avenant" model="ir.actions.act_window">
        <field name="name">Avenants</field>
        <field name="res_model">chantier.avenant</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
