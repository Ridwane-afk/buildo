<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_chantier_commande_fournisseur_form" model="ir.ui.view">
        <field name="name">chantier.commande.fournisseur.form</field>
        <field name="model">chantier.commande.fournisseur</field>
        <field name="arch" type="xml">
            <form string="Commande fournisseur">
                <header>
                    <button name="action_envoyer" string="Envoyer" type="object"
                            invisible="state != 'brouillon'" class="btn-primary"/>
                    <button name="action_receptionner" string="Réceptionner" type="object"
                            invisible="state != 'envoye'" class="btn-primary"/>
                    <button name="action_annuler" string="Annuler" type="object"
                            invisible="state not in ('brouillon', 'envoye')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="brouillon,envoye,recu"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="chantier_id"/>
                            <field name="fournisseur_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="date_livraison_prevue"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <field name="ligne_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="materiau_id"/>
                            <field name="description"/>
                            <field name="quantite"/>
                            <field name="unite"/>
                            <field name="prix_unitaire"/>
                            <field name="sous_total" sum="Total"/>
                        </list>
                    </field>
                    <group class="oe_subtotal_footer">
                        <field name="montant_total" class="oe_subtotal_footer_separator"/>
                    </group>
                    <field name="note" placeholder="Note..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_chantier_commande_fournisseur_list" model="ir.ui.view">
        <field name="name">chantier.commande.fournisseur.list</field>
        <field name="model">chantier.commande.fournisseur</field>
        <field name="arch" type="xml">
            <list string="Commandes fournisseur">
                <field name="name"/>
                <field name="chantier_id"/>
                <field name="fournisseur_id"/>
                <field name="date"/>
                <field name="date_livraison_prevue"/>
                <field name="montant_total" sum="Total"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'recu'"
                       decoration-warning="state == 'envoye'"
                       decoration-danger="state == 'annule'"/>
            </list>
        </field>
    </record>

    <record id="action_chantier_commande_fournisseur" model="ir.actions.act_window">
        <field name="name">Commandes fournisseur</field>
        <field name="res_model">chantier.commande.fournisseur</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
