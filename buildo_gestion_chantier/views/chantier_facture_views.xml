<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_chantier_facture_form" model="ir.ui.view">
        <field name="name">chantier.facture.form</field>
        <field name="model">chantier.facture</field>
        <field name="arch" type="xml">
            <form string="Facture">
                <header>
                    <button name="action_envoyer" string="Envoyer" type="object"
                            invisible="state != 'brouillon'" class="btn-primary"/>
                    <button name="action_marquer_payee" string="Marquer payée" type="object"
                            invisible="state != 'envoyee'" class="btn-primary"/>
                    <button name="action_annuler" string="Annuler" type="object"
                            invisible="state not in ('brouillon', 'envoyee')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="brouillon,envoyee,payee"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="chantier_id"/>
                            <field name="client_id"/>
                            <field name="devis_id"/>
                            <field name="type_facture"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="date_echeance"/>
                            <field name="pourcentage_avancement"
                                   invisible="type_facture != 'avancement'"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group class="oe_subtotal_footer">
                        <field name="montant_ht"/>
                        <field name="tva"/>
                        <field name="montant_total" class="oe_subtotal_footer_separator"/>
                    </group>
                    <field name="note" placeholder="Note..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_chantier_facture_list" model="ir.ui.view">
        <field name="name">chantier.facture.list</field>
        <field name="model">chantier.facture</field>
        <field name="arch" type="xml">
            <list string="Factures" decoration-success="state == 'payee'"
                  decoration-danger="state == 'annulee'">
                <field name="name"/>
                <field name="chantier_id"/>
                <field name="client_id"/>
                <field name="date"/>
                <field name="date_echeance"/>
                <field name="type_facture"/>
                <field name="montant_total" sum="Total"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'payee'"
                       decoration-warning="state == 'envoyee'"
                       decoration-danger="state == 'annulee'"/>
            </list>
        </field>
    </record>

    <record id="action_chantier_facture" model="ir.actions.act_window">
        <field name="name">Factures</field>
        <field name="res_model">chantier.facture</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
