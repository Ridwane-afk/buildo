<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_chantier_heure_prestee_form" model="ir.ui.view">
        <field name="name">chantier.heure.prestee.form</field>
        <field name="model">chantier.heure.prestee</field>
        <field name="arch" type="xml">
            <form string="Heures prestées">
                <header>
                    <button name="action_soumettre" string="Soumettre" type="object"
                            invisible="state != 'brouillon'" class="btn-primary"/>
                    <button name="action_valider" string="Valider" type="object"
                            invisible="state != 'soumis'" class="btn-primary"
                            groups="buildo_gestion_chantier.group_chef_chantier"/>
                    <button name="action_refuser" string="Refuser" type="object"
                            invisible="state != 'soumis'"
                            groups="buildo_gestion_chantier.group_chef_chantier"/>
                    <button name="action_reset" string="Remettre en brouillon" type="object"
                            invisible="state not in ('soumis', 'refuse')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="brouillon,soumis,valide"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="chantier_id"/>
                            <field name="ouvrier_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="nb_heures"/>
                            <field name="taux_horaire"/>
                            <field name="montant"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Description du travail effectué..."/>
                    <field name="note_refus" invisible="state != 'refuse'"
                           placeholder="Motif du refus..."/>
                    <field name="validateur_id" invisible="state != 'valide'" readonly="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_chantier_heure_prestee_list" model="ir.ui.view">
        <field name="name">chantier.heure.prestee.list</field>
        <field name="model">chantier.heure.prestee</field>
        <field name="arch" type="xml">
            <list string="Heures prestées" decoration-success="state == 'valide'"
                  decoration-danger="state == 'refuse'">
                <field name="chantier_id"/>
                <field name="ouvrier_id"/>
                <field name="date"/>
                <field name="nb_heures"/>
                <field name="taux_horaire"/>
                <field name="montant" sum="Total"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'valide'"
                       decoration-danger="state == 'refuse'"
                       decoration-warning="state == 'soumis'"/>
            </list>
        </field>
    </record>

    <record id="action_chantier_heure_prestee" model="ir.actions.act_window">
        <field name="name">Heures prestées</field>
        <field name="res_model">chantier.heure.prestee</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
