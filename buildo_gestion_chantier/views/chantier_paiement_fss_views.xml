<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_chantier_paiement_fss_list" model="ir.ui.view">
        <field name="name">chantier.paiement.fss.list</field>
        <field name="model">chantier.paiement.fss</field>
        <field name="arch" type="xml">
            <list string="Paiements FSS" decoration-success="state == 'paye'"
                  decoration-warning="state == 'a_payer'">
                <field name="chantier_id"/>
                <field name="ouvrier_id"/>
                <field name="periode"/>
                <field name="date"/>
                <field name="montant" sum="Total"/>
                <field name="reference_paiement"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'paye'"
                       decoration-warning="state == 'a_payer'"/>
                <button name="action_marquer_paye" string="Marquer payé" type="object"
                        invisible="state != 'a_payer'" class="btn-sm btn-primary"/>
            </list>
        </field>
    </record>

    <record id="view_chantier_paiement_fss_form" model="ir.ui.view">
        <field name="name">chantier.paiement.fss.form</field>
        <field name="model">chantier.paiement.fss</field>
        <field name="arch" type="xml">
            <form string="Paiement FSS">
                <header>
                    <button name="action_marquer_paye" string="Marquer payé" type="object"
                            invisible="state != 'a_payer'" class="btn-primary"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="chantier_id"/>
                            <field name="ouvrier_id"/>
                            <field name="periode"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="montant"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="reference_paiement"/>
                        </group>
                    </group>
                    <field name="note" placeholder="Note..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_chantier_paiement_fss" model="ir.actions.act_window">
        <field name="name">Paiements FSS</field>
        <field name="res_model">chantier.paiement.fss</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
