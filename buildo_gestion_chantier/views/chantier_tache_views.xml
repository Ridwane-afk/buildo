<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_chantier_tache_list" model="ir.ui.view">
        <field name="name">chantier.tache.list</field>
        <field name="model">chantier.tache</field>
        <field name="arch" type="xml">
            <list string="Tâches" editable="bottom"
                  decoration-success="state == 'fait'" decoration-danger="state == 'bloque'">
                <field name="sequence" widget="handle"/>
                <field name="chantier_id"/>
                <field name="name"/>
                <field name="responsable_id"/>
                <field name="date_debut"/>
                <field name="date_fin"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'fait'"
                       decoration-warning="state == 'en_cours'"
                       decoration-danger="state == 'bloque'"/>
            </list>
        </field>
    </record>

    <record id="view_chantier_tache_form" model="ir.ui.view">
        <field name="name">chantier.tache.form</field>
        <field name="model">chantier.tache</field>
        <field name="arch" type="xml">
            <form string="Tâche">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="chantier_id"/>
                        <field name="responsable_id"/>
                        <field name="date_debut"/>
                        <field name="date_fin"/>
                        <field name="state"/>
                    </group>
                    <field name="description" placeholder="Description de la tâche..."/>
                    <field name="note" placeholder="Notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_chantier_tache" model="ir.actions.act_window">
        <field name="name">Tâches</field>
        <field name="res_model">chantier.tache</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
