<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_chantier_devis_form" model="ir.ui.view">
        <field name="name">chantier.devis.form</field>
        <field name="model">chantier.devis</field>
        <field name="arch" type="xml">
            <form string="Devis">
                <header>
                    <button name="action_envoyer" string="Envoyer" type="object"
                            invisible="state != 'brouillon'" class="btn-primary"/>
                    <button name="action_accepter" string="Accepter" type="object"
                            invisible="state != 'envoye'" class="btn-primary"/>
                    <button name="action_refuser" string="Refuser" type="object"
                            invisible="state != 'envoye'"/>
                    <button name="action_annuler" string="Annuler" type="object"
                            invisible="state not in ('brouillon', 'envoye')"/>
                    <button name="action_reset_draft" string="Remettre en brouillon" type="object"
                            invisible="state not in ('refuse', 'annule')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="brouillon,envoye,accepte"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="chantier_id"/>
                            <field name="client_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="date_validite"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <field name="ligne_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="type_ligne"/>
                            <field name="name"/>
                            <field name="quantite"/>
                            <field name="unite"/>
                            <field name="prix_unitaire"/>
                            <field name="sous_total" sum="Total HT"/>
                        </list>
                    </field>
                    <group class="oe_subtotal_footer">
                        <field name="montant_ht" class="oe_subtotal_footer_separator"/>
                        <field name="tva"/>
                        <field name="montant_ttc" class="oe_subtotal_footer_separator"/>
                    </group>
                    <field name="note" placeholder="Conditions et remarques..."/>
                    <notebook>
                        <page string="Avenants">
                            <field name="avenant_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="motif"/>
                                    <field name="montant_ht"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Factures liées">
                            <field name="facture_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="type_facture"/>
                                    <field name="montant_total"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_chantier_devis_list" model="ir.ui.view">
        <field name="name">chantier.devis.list</field>
        <field name="model">chantier.devis</field>
        <field name="arch" type="xml">
            <list string="Devis" decoration-success="state == 'accepte'"
                  decoration-danger="state == 'refuse'">
                <field name="name"/>
                <field name="chantier_id"/>
                <field name="client_id"/>
                <field name="date"/>
                <field name="date_validite"/>
                <field name="montant_ttc"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'accepte'"
                       decoration-warning="state == 'envoye'"
                       decoration-danger="state == 'refuse'"/>
            </list>
        </field>
    </record>

    <record id="action_chantier_devis" model="ir.actions.act_window">
        <field name="name">Devis</field>
        <field name="res_model">chantier.devis</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
