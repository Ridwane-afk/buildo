<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Heures prestées : un ouvrier ne voit que ses propres heures.
         Un chef ou plus voit toutes les heures (la règle chef est ORée avec
         la règle ouvrier, ce qui lève la restriction pour les rôles supérieurs). -->

    <record id="rule_heure_prestee_ouvrier" model="ir.rule">
        <field name="name">Heures prestées — ouvrier voit ses propres heures</field>
        <field name="model_id" ref="model_chantier_heure_prestee"/>
        <field name="domain_force">[('ouvrier_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_ouvrier'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_heure_prestee_chef" model="ir.rule">
        <field name="name">Heures prestées — chef voit toutes les heures</field>
        <field name="model_id" ref="model_chantier_heure_prestee"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_chef_chantier'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Demandes matériel : même logique que les heures. -->

    <record id="rule_demande_materiel_ouvrier" model="ir.rule">
        <field name="name">Demandes matériel — ouvrier voit ses propres demandes</field>
        <field name="model_id" ref="model_chantier_demande_materiel"/>
        <field name="domain_force">[('ouvrier_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_ouvrier'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_demande_materiel_chef" model="ir.rule">
        <field name="name">Demandes matériel — chef voit toutes les demandes</field>
        <field name="model_id" ref="model_chantier_demande_materiel"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_chef_chantier'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Chantiers : un chef ne voit que les chantiers dont il est responsable.
         Le service administratif et les rôles supérieurs voient tout. -->

    <record id="rule_chantier_chef" model="ir.rule">
        <field name="name">Chantiers — chef voit ses chantiers uniquement</field>
        <field name="model_id" ref="model_chantier_chantier"/>
        <field name="domain_force">[('chef_chantier_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_chef_chantier'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_chantier_service_admin" model="ir.rule">
        <field name="name">Chantiers — service administratif voit tous les chantiers</field>
        <field name="model_id" ref="model_chantier_chantier"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_service_administratif'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>
