<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="res.groups.privilege" id="privilege_buildo">
        <field name="name">BUILDO Gestion chantiers</field>
        <field name="sequence">100</field>
        <field name="category_id" ref="base.module_category_services"/>
    </record>

    <record id="group_ouvrier" model="res.groups">
        <field name="name">Ouvrier</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="privilege_buildo"/>
        <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
    </record>

    <record id="group_chef_chantier" model="res.groups">
        <field name="name">Chef de chantier</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="privilege_buildo"/>
        <field name="implied_ids" eval="[(4, ref('group_ouvrier'))]"/>
    </record>

    <record id="group_service_administratif" model="res.groups">
        <field name="name">Service administratif</field>
        <field name="sequence">30</field>
        <field name="privilege_id" ref="privilege_buildo"/>
        <field name="implied_ids" eval="[(4, ref('group_chef_chantier'))]"/>
    </record>

    <record id="group_direction" model="res.groups">
        <field name="name">Direction / Entrepreneur</field>
        <field name="sequence">40</field>
        <field name="privilege_id" ref="privilege_buildo"/>
        <field name="implied_ids" eval="[(4, ref('group_service_administratif'))]"/>
    </record>

    <record id="group_admin_buildo" model="res.groups">
        <field name="name">Administrateur BUILDO</field>
        <field name="sequence">50</field>
        <field name="privilege_id" ref="privilege_buildo"/>
        <field name="implied_ids" eval="[(4, ref('group_direction'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
